{
  "name": "student-platform-backend",
  "version": "1.0.0",
  "description": "Enroll platform API — Express, Sequelize, PostgreSQL",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "cross-env NODE_ENV=development nodemon --exec ts-node server.ts",
    "dev": "cross-env NODE_ENV=development nodemon --exec ts-node server.ts",
    "build": "tsc",
    "start:dev": "cross-env NODE_ENV=development pm2 start dist/server.js --name enroll-api",
    "start:staging": "cross-env NODE_ENV=staging pm2 start dist/server.js --name enroll-api",
    "start:production": "cross-env NODE_ENV=production pm2 start dist/server.js --name enroll-api",
    "lint": "eslint .",
    "lint:error": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format-lint": "npm run format && npm run lint:error && tsc",
    "migrate:chatbot": "cross-env NODE_ENV=development ts-node scripts/apply-chatbot-migration.ts",
    "sync:chat-knowledge": "cross-env NODE_ENV=development ts-node scripts/sync-chat-knowledge.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "chalk": "^5.4.1",
    "colors": "^1.4.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint-plugin-unused-imports": "^4.1.4",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.1",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-mailjet": "^6.0.6",
    "nodemailer": "^6.9.14",
    "openai": "^6.37.0",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
