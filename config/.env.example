# Environment template (copy to `config/.env.development` etc.)

# App URLs (password-reset links and email CTAs)
# FRONTEND_URL=http://localhost:8080
# BACKEND_URL=http://localhost:4001

# Brevo transactional email (SMTP)
# BREVO_API_KEY=xsmtpsib-...   OR REST API key xkeysib-...
# BREVO_SMTP_LOGIN=123abc@smtp-brevo.com   (required for xsmtpsib — from Brevo SMTP tab)
# EMAIL_FROM=info@educratsglobal.com
# EMAIL_FROM_NAME=Uniwizer
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587

# Counselling appointment email reminders (24h + 1h before; runs every 15 min by default)
# CRON_COUNSELLING_REMINDERS_ENABLED=true
# CRON_COUNSELLING_REMINDERS_SCHEDULE=*/15 * * * *
# Run migration once: psql $DATABASE_URL -f migrations/010_appointment_email_reminders.sql

# Didit KYC / identity verification
# DIDIT_API_KEY=
# DIDIT_BASE_URL=https://verification.didit.me
# DIDIT_WORKFLOW_ID=          # required — from Didit Console → Workflows
# DIDIT_WEBHOOK_SECRET=       # secret_shared_key from webhook destination
# Register webhook: POST https://verification.didit.me/v3/webhook/destinations/
#   url: https://your-backend/api/v1/didit/webhook
#   subscribed_events: ["status.updated"]
# Run migration: psql $DATABASE_URL -f migrations/011_didit_verification_sessions.sql

# Document verification (OCR + passport/bank/ITR tables)
# Run migration: npm run migrate:verification
#   (or psql $DATABASE_URL -f migrations/012_document_verification.sql)

# OpenAI — required for chat completions and knowledge sync embeddings
OPENAI_API_KEY=
# Optional overrides:
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Notice ticker — AI sync from RSS (runs on cron; no manual CRUD)
# CRON_NOTICES_ENABLED=true
# CRON_NOTICES_SCHEDULE=0 */6 * * *
# NOTICE_AI_ENABLED=true
# NOTICE_RSS_FEEDS=https://www.gov.uk/government/organisations/uk-visas-and-immigration.atom,https://www.thepienews.com/feed/,https://www.studyinternational.com/feed/
# NOTICE_AI_MAX_ITEMS=5
# NOTICE_AI_MAX_ACTIVE=10
# NOTICE_AI_MAX_AGE_HOURS=72
# NOTICE_AI_RETENTION_DAYS=30
# Run migrations once: npm run migrate:notices && npm run migrate:notice-ai
# Manual sync: npm run sync:notices  (or POST /api/v1/admin/notices/sync-ai)

# Then `npm run sync:chat-knowledge` after OPENAI_API_KEY is set.

# RabbitMQ — IDP/AECC course scraping
# Start locally: npm run docker:up  (requires Docker Desktop)
RABBITMQ_URL=amqp://guest:guest@localhost:5672
# Use 0 for long Playwright scrapes (recommended). Set e.g. 60 for short-lived API-only connections.
RABBITMQ_HEARTBEAT=3600

# Scraping tuning
# SCRAPE_MAX_RETRIES=3
# CLEAN_MAX_RETRIES=3
# SCRAPE_TIMEOUT_MS=120000
# SCRAPE_RATE_LIMIT_MS=2000
# SCRAPE_MAX_PAGES=25
# SCRAPE_MAX_DETAIL_PAGES=15
# SCRAPE_MAX_API_RESPONSES=24
# SCRAPE_USER_AGENT=UniwizerPlatformBot/1.0 (+https://uniwizer.com; course-research)
# SCRAPE_LOG_LEVEL=info
# SCRAPE_LOG_FILE=logs/scrape.log

# Custom website scrape limits
# SCRAPE_CUSTOM_MAX_PAGES=25
# SCRAPE_CUSTOM_MAX_DETAIL=15

# Cron preset sources (IDP,AECC only for scheduled jobs)
# CRON_SCRAPE_SOURCES=IDP,AECC

# Google OAuth (Calendar / Sign-in) — from Google Cloud Console OAuth 2.0 client
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PROJECT_ID=
# GOOGLE_REDIRECT_URI=http://localhost:4001/api/v1/admin/google/callback
# GOOGLE_JAVASCRIPT_ORIGIN=https://uniwizer.io
# GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/userinfo.email
# GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:3380/admin/settings/calendar?connected=1
# GOOGLE_OAUTH_ERROR_REDIRECT=http://localhost:3380/admin/settings/calendar?connected=0
# SCHEDULING_SLOT_MINUTES=45
# SCHEDULING_TIMEZONE=Asia/Kolkata
# DEFAULT_COUNSELLOR_ADMIN_USER_ID=

# After RabbitMQ is running, start BOTH workers (separate terminals):
#   npm run worker:scraper
#   npm run worker:cleaner
# Optional: npm run dev:worker / npm run dev:worker:cleaner
# SCRAPE_PAGE_RETRIES=3
# SCRAPE_PAGE_WAIT_MS=3000
# SCRAPE_AI_ENRICHMENT=true
# SCRAPE_OPENAI_MODEL=gpt-4o-mini
# SCRAPE_AI_DELAY_MS=300
# SCRAPE_RAW_CHUNK_SIZE=25

# Dev stack (npm run dev): starts API + scraper + enricher workers + RabbitMQ docker
# Stop everything: npm run dev:stop   (add --jobs to cancel in-flight scrape jobs)
# KEEP_DOCKER=1 npm run dev:stop      — leave RabbitMQ running
# SKIP_DOCKER=1
# Dev admin (run once): npm run seed:admin
# DEV_ADMIN_EMAIL=admin@example.com
# DEV_ADMIN_PASSWORD=SecurePass1
# Playwright browsers (once): `npx playwright install chromium`
# Smoke tests: npm run test:scrape:idp / npm run test:scrape:aecc
